# 监控配置
# 目标事件的 Slug (在 Polymarket URL 中找到，例如 polymarket.com/event/xxx 中的 xxx)
EVENT_SLUG=will-bitcoin-reach-100k-in-2024

# 轮询间隔 (毫秒)
POLL_INTERVAL=5000

# 变动阈值 (绝对值，例如 0.05 代表 5% 的概率变动)
CHANGE_THRESHOLD=0.05

# 代理设置 (如果在国内无法访问，请填写你的代理地址，例如 http://127.0.0.1:7890)
# HTTP_PROXY=http://127.0.0.1:7890

# Telegram 通知配置 (可选)
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
